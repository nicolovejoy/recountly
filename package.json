{
  "name": "recountly",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "(sleep 1.5 && open http://localhost:8255) & next dev -p 8255",
    "dev:noopen": "next dev -p 8255",
    "build": "next build",
    "start": "next start -p 8255",
    "lint": "eslint",
    "db:migrate": "node --env-file=.env.local scripts/migrate.mjs",
    "db:auth-migrate": "node --env-file=.env.local node_modules/@better-auth/cli/dist/index.mjs migrate -y",
    "seed:user": "node --env-file=.env.local scripts/seed-user.mjs",
    "db:introspect": "node --env-file=.env.local scripts/db-introspect.mjs",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@neondatabase/serverless": "1.1.0",
    "@vercel/blob": "2.4.0",
    "better-auth": "1.6.20",
    "fix-webm-duration": "1.0.6",
    "next": "16.2.7",
    "pg": "8.22.0",
    "react": "19.2.4",
    "react-dom": "19.2.4"
  },
  "devDependencies": {
    "@better-auth/cli": "1.4.21",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/pg": "8.20.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.7",
    "tailwindcss": "^4",
    "typescript": "^5",
    "vitest": "^4.1.8"
  }
}
